{
  "includeCoAuthoredBy": false,
  "statusLine": {
    "type": "command",
    "command": "ccstatusline",
    "padding": 0
  },
  "enabledPlugins": {},
  "alwaysThinkingEnabled": true,
  "permissions": {
    "allow": [
      "Bash(workmux add:*)",
      "Bash(workmux wait:*)",
      "Bash(workmux status:*)",
      "Bash(workmux capture:*)",
      "Bash(workmux run:*)",
      "Bash(workmux send:*)",
      "Bash(workmux remove:*)",
      "Bash(pueue add:*)",
      "Bash(pueue status:*)",
      "Bash(pueue log:*)",
      "Bash(pueue follow:*)",
      "Bash(gh push:*)",
      "Bash(gh release:*)"
    ]
  },
  "hooks": {
      "Notification": [
        {
          "matcher": "permission_prompt|elicitation_dialog",
          "hooks": [
            {
              "type": "command",
              "command": "workmux set-window-status waiting"
            }
          ]
        }
      ],
      "PostToolUse": [
        {
          "hooks": [
            {
              "type": "command",
              "command": "workmux set-window-status working"
            }
          ]
        }
      ],
      "Stop": [
        {
          "hooks": [
            {
              "type": "command",
              "command": "workmux set-window-status done"
            }
          ]
        }
      ],
      "UserPromptSubmit": [
        {
          "hooks": [
            {
              "type": "command",
              "command": "workmux set-window-status working"
            }
          ]
        }
      ]
    },
  "skipDangerousModePermissionPrompt": true
}
